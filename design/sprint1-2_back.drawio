        <mxCell id="Bb3nLOViEVlyO2GLfGhX-17" value="Gabia&lt;div&gt;DNS&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="Bb3nLOViEVlyO2GLfGhX-15">
