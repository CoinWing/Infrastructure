        <mxCell id="1MrtU10jNGN_QD_TYwTv-73" value="프론트엔드 -&amp;gt; API Gateway (인증용)&lt;div&gt;사용자가 로그인 또는 회원가입 버튼 클릭 시, 프론트엔드가 &lt;span data-end=&quot;236&quot; data-start=&quot;215&quot;&gt;인증 전용 API Gateway&lt;/span&gt;에 요청을 보냄&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="2075" y="42" width="449" height="58" as="geometry" />
        </mxCell>
        <mxCell id="1MrtU10jNGN_QD_TYwTv-74" value="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=none;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;" parent="1" vertex="1">
          <mxGeometry x="910" y="937.5" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="1MrtU10jNGN_QD_TYwTv-75" value="2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=none;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;" parent="1" vertex="1">
          <mxGeometry x="1190" y="884" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="1MrtU10jNGN_QD_TYwTv-76" value="3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=none;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;" parent="1" vertex="1">
          <mxGeometry x="1444" y="964" width="40" height="38" as="geometry" />
