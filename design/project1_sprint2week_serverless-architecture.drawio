        <mxCell id="1MrtU10jNGN_QD_TYwTv-73" value="프론트엔드 -&amp;gt; API Gateway (인증용)&lt;div&gt;사용자가 로그인 또는 회원가입 버튼 클릭 시, 프론트엔드가 &lt;span data-end=&quot;236&quot; data-start=&quot;215&quot;&gt;인증 전용 API Gateway&lt;/span&gt;에 요청을 보냄&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" parent="Bb3nLOViEVlyO2GLfGhX-57" vertex="1">
          <mxGeometry x="70" y="8" width="449" height="58" as="geometry" />
        </mxCell>
        <mxCell id="1MrtU10jNGN_QD_TYwTv-83" value="2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=none;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;" parent="Bb3nLOViEVlyO2GLfGhX-57" vertex="1">
          <mxGeometry x="18.5" y="86.5" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="1MrtU10jNGN_QD_TYwTv-84" value="API Gateway -&amp;gt; Lambda (회원가입 or 로그)&lt;br&gt;&lt;div&gt;API Gateway는 요청 경로에 따라 &lt;span style=&quot;&quot; data-end=&quot;327&quot; data-start=&quot;312&quot;&gt;회원가입 Lambda&lt;/span&gt; 또는 &lt;span style=&quot;&quot; data-end=&quot;345&quot; data-start=&quot;331&quot;&gt;로그인 Lambda&lt;/span&gt;로 트래픽을 라우팅&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" parent="Bb3nLOViEVlyO2GLfGhX-57" vertex="1">
          <mxGeometry x="70" y="82" width="449" height="54" as="geometry" />
        </mxCell>
        <mxCell id="1MrtU10jNGN_QD_TYwTv-85" value="3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=none;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;" parent="Bb3nLOViEVlyO2GLfGhX-57" vertex="1">
          <mxGeometry x="19.25" y="154.5" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="1MrtU10jNGN_QD_TYwTv-86" value="Lambda -&amp;gt; RDS (인증 DB)&lt;div&gt;Lambda는 RDS에 접근하여 사용자 정보 생성 또는 검증을 수행함&lt;br&gt;(예: 이메일 중복 확인, 비밀번호 해시 비교 등)&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" parent="Bb3nLOViEVlyO2GLfGhX-57" vertex="1">
          <mxGeometry x="70.75" y="150" width="449" height="58" as="geometry" />
        </mxCell>
        <mxCell id="1MrtU10jNGN_QD_TYwTv-87" value="4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=none;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;" parent="Bb3nLOViEVlyO2GLfGhX-57" vertex="1">
          <mxGeometry x="19.25" y="226.5" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="1MrtU10jNGN_QD_TYwTv-88" value="프론트엔드 -&amp;gt; ECS&lt;div&gt;사용자가 모의 거래를 시도할 경우 (시장가/지정가 매수·매도), 프론트엔드는 &lt;span style=&quot;&quot; data-end=&quot;529&quot; data-start=&quot;522&quot;&gt;ECS&lt;/span&gt;로 요청을 보냄&lt;br&gt;(이 요청에는 어떤 거래를 시도하려는지, 어떤 코인인지 등의 정보가 포함됨)&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" parent="Bb3nLOViEVlyO2GLfGhX-57" vertex="1">
          <mxGeometry x="70.75" y="222" width="449" height="54" as="geometry" />
        </mxCell>
        <mxCell id="1MrtU10jNGN_QD_TYwTv-89" value="5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=none;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;" parent="Bb3nLOViEVlyO2GLfGhX-57" vertex="1">
          <mxGeometry x="17.75" y="312.5" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="1MrtU10jNGN_QD_TYwTv-90" value="&lt;div&gt;ECS &amp;lt;-&amp;gt; Websocket&lt;/div&gt;&lt;div&gt;ECS 인스턴스는 &lt;span style=&quot;&quot; data-end=&quot;645&quot; data-start=&quot;624&quot;&gt;업비트의 WebSocket 서버&lt;/span&gt;와 지속적으로 연결되어&lt;br&gt;실시간 체결가, 주문장, 거래량 등의 데이터를 수신함&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" parent="Bb3nLOViEVlyO2GLfGhX-57" vertex="1">
          <mxGeometry x="69.25" y="308" width="449" height="58" as="geometry" />
        </mxCell>
        <mxCell id="1MrtU10jNGN_QD_TYwTv-91" value="6" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=none;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;" parent="Bb3nLOViEVlyO2GLfGhX-57" vertex="1">
          <mxGeometry x="17.75" y="386.5" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="1MrtU10jNGN_QD_TYwTv-92" value="&lt;div&gt;ECS -&amp;gt; API Gateway (거래용)&lt;/div&gt;&lt;div&gt;ECS는 수신한 프론트 요청과 업비트 시세를 바탕으로&lt;span style=&quot;&quot; data-end=&quot;780&quot; data-start=&quot;759&quot;&gt;거래 전용 API Gateway&lt;/span&gt;로 요청을 전달&lt;br&gt;(예: 시장가 매수 요청 → Lambda 매수 함수로 전달)&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" parent="Bb3nLOViEVlyO2GLfGhX-57" vertex="1">
          <mxGeometry x="69.25" y="382" width="449" height="54" as="geometry" />
        </mxCell>
        <mxCell id="1MrtU10jNGN_QD_TYwTv-93" value="7" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=none;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;" parent="Bb3nLOViEVlyO2GLfGhX-57" vertex="1">
          <mxGeometry x="18.5" y="469.5" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="1MrtU10jNGN_QD_TYwTv-94" value="API Gateway -&amp;gt; Lambda (시장가 매수/ 시장가 매도/ 지정)&lt;br&gt;&lt;div&gt;API Gateway는 요청을 세 종류의 거래 Lambda 중 하나로 라우팅함&lt;/div&gt;&lt;div&gt;(시장가 매수 / 시장가 매도 / 지정가 거래)&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" parent="Bb3nLOViEVlyO2GLfGhX-57" vertex="1">
          <mxGeometry x="70" y="465" width="449" height="58" as="geometry" />
        </mxCell>
        <mxCell id="1MrtU10jNGN_QD_TYwTv-95" value="8" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=none;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;" parent="Bb3nLOViEVlyO2GLfGhX-57" vertex="1">
